{
    "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "analysis": {
            "char_filter": {
                "ignore_quotes": {
                    "type": "mapping",
                    "mappings": [
                        "\u0091=>",
                        "\u0092=>",
                        "\"=>",
                        "'=>",
                        "“=>",
                        "”=>",
                        "‘=>",
                        "’=>",
                        "`=>"
                    ]
                },
                "replace_symbols": {
                    "type": "mapping",
                    "mappings": [
                        "\\u00B7=> ",
                        "\\u00A0=> ",
                        "\\u1680=> ",
                        "\\u180E=> ",
                        "\\u2000=> ",
                        "\\u2001=> ",
                        "\\u2002=> ",
                        "\\u2003=> ",
                        "\\u2004=> ",
                        "\\u2005=> ",
                        "\\u2006=> ",
                        "\\u2007=> ",
                        "\\u2008=> ",
                        "\\u2009=> ",
                        "\\u200A=> ",
                        "\\u202F=> ",
                        "\\u205F=> ",
                        "\\u3000=> ",
                        "\\u0009=> ",
                        "\\u200B=>",
                        "\\uFEFF=>"
                    ]
                },
                "remove_punctuation": {
                    "pattern": "\\p{Punct}+",
                    "type": "pattern_replace",
                    "replacement": " "
                },
                "reduce_whitespace": {
                    "pattern": "\\p{Space}+",
                    "type": "pattern_replace",
                    "replacement": " "
                }
            },
            "filter": {
                "autocomplete_filter": {
                    "type": "edge_ngram",
                    "min_gram": 1,
                    "max_gram": 20
                }
            },
            "normalizer": {
                "uppercase": {
                  "type": "custom",
                  "filter": [
                    "uppercase",
                    "asciifolding"
                  ]
                }
            },
            "analyzer": {
                "folding": {
                    "char_filter": [
                        "ignore_quotes",
                        "replace_symbols",
                        "remove_punctuation",
                        "reduce_whitespace"
                    ],
                    "type": "custom",
                    "tokenizer": "keyword",
                    "filter": [
                        "lowercase",
                        "asciifolding"
                    ]
                },
                "autocomplete": {
                    "char_filter": [
                        "ignore_quotes",
                        "replace_symbols",
                        "remove_punctuation",
                        "reduce_whitespace"
                    ],
                    "type": "custom",
                    "tokenizer": "standard",
                    "filter": [
                        "lowercase",
                        "asciifolding",
                        "autocomplete_filter"
                    ]
                }
            }
        }
    },
    "mappings": {
        "_doc": {
            "dynamic": "strict",

            "properties": {
                "cui": {
                    "type": "keyword",
                    "normalizer": "uppercase"
                },
                "str": {
                    "type": "text",
                    "analyzer": "autocomplete"
                },
                "exact": {
                    "type": "text",
                    "analyzer": "folding"
                },
                "pref": {
                    "type": "text",
                    "index": false
                },
                "source": {
                    "type": "text",
                    "index": false
                },
                "lang": {
                    "type": "text",
                    "index": false
                },
                "types": {
                    "type": "text",
                    "index": false
                }
            }
        }
    }
}
