{
  "name": "ct-autocompletion",
  "version": "2.0.0",
  "description": "Relevant UMLS terms based on user input",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node ./node_modules/nodemon/bin/nodemon.js app.js",
    "test": "set PORT=4088 && mocha -R spec --recursive ./test"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:CTcue/ctAutocompletion.git"
  },
  "keywords": [
    "umls",
    "autosuggest",
    "autocomplete"
  ],
  "dependencies": {
    "@koa/cors": "2",
    "co-monk": "1.0.0",
    "elasticsearch": "15.0.0",
    "elasticsearch-writable-stream": "2.0.1",
    "koa": "2.5.1",
    "koa-body": "4.0.3",
    "koa-cors": "0.0.16",
    "koa-logger": "3.2.0",
    "koa-router": "7.4.0",
    "lodash": "4.17.10",
    "minimist": "1.2.0",
    "moment": "2.22.2",
    "mongodb": "3.1.0-beta4",
    "mongodb-core": "3.1.0-beta4",
    "monk": "6.0.6"
  },
  "devDependencies": {
    "split2": "2.1.0",
    "through2": "2.0.1",
    "mocha": "5.2.0",
    "nodemon": "1.17.5",
    "supertest": "3.1.0"
  },
