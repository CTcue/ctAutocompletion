{
  "name": "ct-autocompletion",
  "version": "2.0.0",
  "description": "Relevant UMLS terms based on user input",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node ./node_modules/nodemon/bin/nodemon.js app.js",
    "test": "set PORT=4088 && mocha --harmony -R spec --recursive ./test"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:CTcue/ctAutocompletion.git"
  },
  "keywords": [
    "umls",
    "autosuggest",
    "autocomplete"
  ],
  "dependencies": {
    "cheerio": "0.22.0",
    "co-monk": "1.0.0",
    "elasticsearch": "15.0.0",
    "elasticsearch-writable-stream": "2.0.0",
    "koa": "2.5.0",
    "koa-cors": "0.0.16",
    "koa-router": "5.4.0",
    "lodash": "4.17.10",
    "minimist": "1.2.0",
    "moment": "2.22.2",
    "mongodb": "2.2.22",
    "mongodb-core": "2.1.7",
    "monk": "3.1.4",
    "request": "2.87.0",
    "request-json": "0.6.3",
    "split2": "^2.1.0",
    "through2": "^2.0.1",
    "winston": "^2.3.0"
  },
  "devDependencies": {
    "supertest": "3.0.0",
    "mocha": "5.2.0",
    "nodemon": "1.17.5"
  },
  "license": "Proprietary",
